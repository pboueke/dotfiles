{
    "height": 30,
    "spacing": 6,
    "modules-left": ["sway/workspaces", "sway/mode", "sway/scratchpad"],
    "modules-center": ["sway/window"],
    "modules-right": ["idle_inhibitor", "pulseaudio", "network", "cpu", "memory", "temperature", "backlight", "battery", "keyboard-state", "clock", "tray"],

    "sway/mode": {
        "format": "[{}]"
    },
    "sway/scratchpad": {
        "format": "scratch: {count}",
        "show-empty": false,
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name}: {icon}",
        "format-icons": {
            "locked": "on",
            "unlocked": "off"
        }
    },
    "idle_inhibitor": {
        "format": "idle: {icon}",
        "format-icons": {
            "activated": "blocked",
            "deactivated": "allowed"
        }
    },
    "tray": {
        "spacing": 10
    },
    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%H:%M}",
        "format-alt": "{:%Y-%m-%d}"
    },
    "cpu": {
        "format": "cpu: {usage}%",
        "tooltip": false
    },
    "memory": {
        "format": "mem: {}%"
    },
    "temperature": {
        "critical-threshold": 80,
        "format": "temp: {temperatureC}°C",
        "format-critical": "temp: {temperatureC}°C [HOT]"
    },
    "backlight": {
        "format": "bri: {percent}%"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "bat: {capacity}%",
        "format-charging": "bat: {capacity}% [+]",
        "format-plugged": "bat: {capacity}% [AC]",
        "format-alt": "bat: {time}"
    },
    "network": {
        "format-wifi": "wifi: {essid} ({signalStrength}%)",
        "format-ethernet": "eth: {ipaddr}/{cidr}",
        "tooltip-format": "{ifname} via {gwaddr}",
        "format-linked": "{ifname} (no IP)",
        "format-disconnected": "net: disconnected",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        "format": "vol: {volume}% {format_source}",
        "format-bluetooth": "vol: {volume}% [bt] {format_source}",
        "format-bluetooth-muted": "vol: mute [bt] {format_source}",
        "format-muted": "vol: mute {format_source}",
        "format-source": "mic: {volume}%",
        "format-source-muted": "mic: mute",
        "on-click": "pavucontrol"
    }
}
